# pymrsf Configuration Example
# Copy this file to .env and fill in your values

# ============================================================================
# PROVIDER SETTINGS
# ============================================================================
# Provider: local, openai, or anthropic
PYMRSF_PROVIDER=local

# ============================================================================
# LOCAL PROVIDER SETTINGS (for GGUF models via llama-cpp-python)
# ============================================================================
# Path to your GGUF model file
# Example: C:/Users/yourname/models/mistral-7b-v0.1.Q4_K_M.gguf
PYMRSF_MODEL_PATH=/path/to/your/model.gguf

# Context window size (tokens)
PYMRSF_N_CTX=2048

# Number of GPU layers to offload (0 = CPU only, 35 = full GPU for 7B model)
PYMRSF_N_GPU_LAYERS=35

# Number of threads for CPU processing
PYMRSF_N_THREADS=8

# ============================================================================
# EMBEDDING SETTINGS
# ============================================================================
# Ollama API base URL (for local embeddings)
PYMRSF_OLLAMA_BASE=http://localhost:11434

# Embedding model name (used with Ollama)
PYMRSF_EMBED_MODEL=nomic-embed-text

# Embedding request timeout (seconds)
PYMRSF_EMBED_TIMEOUT=30

# ============================================================================
# API PROVIDER SETTINGS
# ============================================================================
# OpenAI API key (required if PYMRSF_PROVIDER=openai)
# Get yours at: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...

# Anthropic API key (required if PYMRSF_PROVIDER=anthropic)
# Get yours at: https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-...

# ============================================================================
# CACHE SETTINGS
# ============================================================================
# Enable result caching
PYMRSF_CACHE_ENABLED=true

# Maximum cache size (number of entries)
PYMRSF_CACHE_MAX_SIZE=10000

# Cache TTL in seconds (3600 = 1 hour)
PYMRSF_CACHE_TTL=3600

# ============================================================================
# ADVANCED SETTINGS
# ============================================================================
# Allow fallback to another provider on failure (true/false)
# Default: false (fail-fast for safety)
PYMRSF_ALLOW_PROVIDER_FALLBACK=false

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
PYMRSF_LOG_LEVEL=INFO

# ============================================================================
# RAG SCORING DEFAULTS
# ============================================================================
# Default minimum RAG score for filtering (0-100)
# PYMRSF_MIN_RAG_SCORE=50

# Default novelty weight (0.0-1.0)
# PYMRSF_NOVELTY_WEIGHT=0.6

# Default relevance weight (0.0-1.0)
# PYMRSF_RELEVANCE_WEIGHT=0.4
